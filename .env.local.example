# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments.

# ===========================================
# REQUIRED FOR PRODUCTION
# ===========================================

# JWT secret for session signing (MUST change in production!)
JWT_SECRET="your-jwt-secret-change-in-production-min-32-chars"

# ===========================================
# GALLERY ACCESS
# ===========================================

# Default gallery password (if not set in admin settings)
NEXT_PUBLIC_ACCESS_PASSWORD="gallery2024"

# ===========================================
# ADMIN PANEL
# ===========================================

# Admin panel password (default: selim123 if nothing else is set).
# If REDIS_URL / KV is configured, set this so your chosen password wins over Redis key luxury_gallery:admin_password.
ADMIN_PASSWORD="selim123"

# vadmin (/vadmin) — yoksa aynı şifre için ADMIN_PASSWORD kullanılır (VADMIN öncelikli).
# VADMIN_PASSWORD="selim123"

# ===========================================
# ORDER CONTACT OPTIONS
# ===========================================

# WhatsApp number for orders (include country code, no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER="905551234567"

# Email for order inquiries
NEXT_PUBLIC_CONTACT_EMAIL="info@gallery.com"

# Instagram username (without @)
NEXT_PUBLIC_INSTAGRAM_USERNAME="gallery"

# ===========================================
# IMAGES
# ===========================================

# Base URL for artwork images (default: /artworks)
# NEXT_PUBLIC_IMAGES_BASE="https://cdn.example.com/gallery"

# Cloudflare R2 (upload/delete — see docs/R2-SETUP.md)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# NEXT_PUBLIC_R2_IMAGE_HOST=pub-xxxxx.r2.dev
